<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link href="/css/output.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-100 font-sans">
    <div class="flex h-screen overflow-hidden">

        <!-- SIDEBAR -->
        <aside id="sidebar"
            class="bg-blue-700 text-white w-64 space-y-6 py-7 px-4 absolute inset-y-0 left-0 transform -translate-x-full md:relative md:translate-x-0 transition duration-200 ease-in-out shadow-lg">

            <!-- Logo -->
            <h2 class="text-2xl font-bold text-center tracking-wide">My App</h2>

            <!-- Menu -->
            <nav class="mt-6">
                <p class="text-xs text-blue-200 px-2 mb-3">PATH: <%= currentPath %></p>

                <!-- Dashboard -->
                <a href="/"
                    class="flex items-center gap-2 py-2.5 px-4 rounded-lg transition
                    <%= currentPath === '/' ? 'bg-blue-900 shadow-inner' : 'hover:bg-blue-600' %>">
                    📊 Dashboard
                </a>

                <!-- MASTER -->
                <div class="mt-3">
                    <button onclick="toggleMenu()"
                        class="w-full flex items-center justify-between py-2.5 px-4 rounded-lg hover:bg-blue-600 transition">
                        <span>📁 Master</span>
                        <span>▾</span>
                    </button>

                    <!-- SUBMENU -->
                    <div id="submenu"
                        class="<%= currentPath.includes('/mahasiswa') ? '' : 'hidden' %> ml-4 mt-2 space-y-2">

                        <a href="/mahasiswa"
                            class="block py-2 px-4 rounded-lg transition
                            <%= currentPath.includes('/mahasiswa') ? 'bg-blue-900 shadow-inner' : 'hover:bg-blue-600' %>">
                            👨‍🎓 Mahasiswa
                        </a>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="flex-1 flex flex-col">

            <!-- HEADER -->
            <header class="bg-white shadow-sm px-6 py-4 flex justify-between items-center border-b">
                
                <!-- Mobile button -->
                <button class="md:hidden text-gray-600 text-xl" onclick="toggleSidebar()">
                    ☰
                </button>

                <h1 class="font-bold text-lg text-gray-800">
                    <%= title %>
                </h1>

                <!-- PROFILE -->
                <div class="relative">
                    <button onclick="toggleProfile()"
                        class="flex items-center gap-2 bg-gray-100 px-4 py-2 rounded-lg hover:bg-gray-200 transition text-sm">
                        👤 Profil
                    </button>

                    <div id="profileMenu"
                        class="hidden absolute right-0 mt-2 bg-white shadow-lg rounded-xl w-40 overflow-hidden border">
                        <a href="#" class="block px-4 py-2 hover:bg-gray-100 text-sm">Profile</a>
                        <a href="#" class="block px-4 py-2 hover:bg-gray-100 text-sm">Logout</a>
                    </div>
                </div>
            </header>

            <!-- CONTENT -->
            <main class="p-6 flex-1 overflow-y-auto bg-gray-50">
                <%- body %>
            </main>

            <!-- FOOTER -->
            <footer class="bg-white text-center p-4 text-sm text-gray-500 border-t">
                © 2026 - Bun MVC App
            </footer>
        </div>
    </div>

    <!-- SCRIPT -->
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
        }

        function toggleMenu() {
            const menu = document.getElementById('submenu');
            menu.classList.toggle('hidden');
        }

        function toggleProfile() {
            const profile = document.getElementById('profileMenu');
            profile.classList.toggle('hidden');
        }
    </script>
</body>
</html>